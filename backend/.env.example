PORT=5000
# Required on Railway — free MongoDB Atlas: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=
MONGOMS_VERSION=6.0.14
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CLIENT_URL=http://localhost:5173
# BatchData (ALL 7 filters — recommended): https://batchdata.io → signup at https://app.batchdata.com
BATCHDATA_API_KEY=
# ATTOM (mortgage, owner, equity): free 30-day trial at https://api.developer.attomdata.com
ATTOM_API_KEY=
# PropRelay (foreclosure — recommended): https://proprelay.com/api-docs.html ($99/mo)
PROPRELAY_API_KEY=
# Bankruptcy Observer (business bankruptcy): https://api.bankruptcyobserver.com/docs
BANKRUPTCY_OBSERVER_TOKEN=

